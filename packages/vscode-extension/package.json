{
  "name": "stencil-vscode",
  "displayName": "Stencil Template Manager",
  "description": "Manage and run Stencil templates directly from VS Code",
  "version": "0.0.1",
  "publisher": "stencil-pm",
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "stencil.runTemplate",
        "title": "Stencil: Run Template"
      },
      {
        "command": "stencil.createTemplate",
        "title": "Stencil: Create Template"
      },
      {
        "command": "stencil.listTemplates",
        "title": "Stencil: List Templates"
      }
    ]
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "dev": "node esbuild.mjs --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "clean": "rm -rf dist",
    "package": "vsce package"
  },
  "dependencies": {
    "@stencil-pm/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/vscode": "^1.96.0",
    "@vscode/test-electron": "^2.4.1",
    "@vscode/vsce": "^3.2.1",
    "esbuild": "^0.24.2",
    "typescript": "^5.7.3"
  }
}
